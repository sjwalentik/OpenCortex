{
  "OpenCortex": {
    "Database": {
      "ConnectionString": "Host=localhost;Port=5432;Database=opencortex;Username=opencortex;Password=opencortex",
      "VectorProvider": "pgvector"
    },
    "Indexing": {
      "DefaultSchedule": "0 */15 * * * *",
      "EnableFileWatching": false
    },
    "Embeddings": {
      "Provider": "deterministic",
      "Model": "opencortex-deterministic-v1",
      "Dimensions": 1536,
      "Endpoint": "",
      "ApiKey": ""
    },
    "Brains": [
      {
        "BrainId": "sample-team",
        "Name": "Sample Team Brain",
        "Slug": "sample-team",
        "Mode": "Filesystem",
        "Status": "active",
        "Tags": ["sample", "self-hosted"],
        "SourceRoots": [
          {
            "SourceRootId": "knowledge-canonical",
            "Path": "knowledge/canonical",
            "PathType": "local",
            "IsWritable": true,
            "IncludePatterns": ["**/*.md"],
            "ExcludePatterns": [],
            "WatchMode": "scheduled"
          }
        ]
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
