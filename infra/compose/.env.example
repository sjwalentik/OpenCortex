# OpenCortex Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# REQUIRED - Database
# =============================================================================
POSTGRES_PASSWORD=your-secure-password-here

# =============================================================================
# OPTIONAL - Database (defaults shown)
# =============================================================================
# POSTGRES_DB=opencortex
# POSTGRES_USER=opencortex
# POSTGRES_PORT=5432

# =============================================================================
# OPTIONAL - Service Ports (defaults shown)
# =============================================================================
# API_PORT=5000
# PORTAL_PORT=5001
# MCP_PORT=5002

# =============================================================================
# OPTIONAL - Embeddings
# =============================================================================
# Provider options: deterministic, openai, ollama
# EMBEDDINGS_PROVIDER=deterministic
# EMBEDDINGS_MODEL=opencortex-deterministic-v1
# EMBEDDINGS_DIMENSIONS=1536
# EMBEDDINGS_API_KEY=
# EMBEDDINGS_ENDPOINT=

# =============================================================================
# OPTIONAL - Firebase Authentication
# =============================================================================
# HOSTED_AUTH_ENABLED=false
# FIREBASE_PROJECT_ID=
# FIREBASE_API_KEY=

# =============================================================================
# OPTIONAL - Admin Access (when hosted auth is enabled)
# =============================================================================
# Admin by Firebase User ID
# ADMIN_USER_ID_0=firebase-user-id-here

# Admin by email pattern (exact match or wildcard like *@example.com)
# ADMIN_EMAIL_PATTERN_0=admin@example.com

# =============================================================================
# OPTIONAL - Stripe Billing
# =============================================================================
# STRIPE_ENABLED=false
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# APP_BASE_URL=https://your-domain.com

# =============================================================================
# OPTIONAL - MCP Server
# =============================================================================
# MCP_BASE_URL=https://mcp.your-domain.com
